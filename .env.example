# ── LLM Provider ─────────────────────────────────────────────
# Active provider: ollama | openai | azure_openai | anthropic
LLM_PROVIDER=ollama
LLM_MODEL=llama3
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Anthropic
ANTHROPIC_API_KEY=

# ── MCP Servers (optional) ────────────────────────────────────
GITHUB_TOKEN=
REPO_PATH=.

# ── Output ────────────────────────────────────────────────────
RCA_OUTPUT_DIR=./rca_reports

# ── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
